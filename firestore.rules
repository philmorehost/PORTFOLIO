rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'philmorehost@gmail.com' && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Project
    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() <= 200 &&
             data.url is string && data.url.size() <= 500 &&
             data.type in ['web', 'app'] &&
             (!('content' in data) || (data.content is string && data.content.size() <= 6000)) &&
             (!('thumbnailUrl' in data) || (data.thumbnailUrl is string && data.thumbnailUrl.size() <= 500)) &&
             (!('galleryImages' in data) || (data.galleryImages is list && data.galleryImages.size() <= 5)) &&
             (!('demoLogin' in data) || (data.demoLogin is map));
    }

    // Validation for Settings
    function isValidSettings(data) {
      return (!('appTitle' in data) || (data.appTitle is string && data.appTitle.size() <= 100)) &&
             (!('heroSubtext' in data) || (data.heroSubtext is string && data.heroSubtext.size() <= 1000));
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming()) && isValidId(settingId);
    }

    match /projects/{projectId} {
      allow read: if true;
      
      allow create: if isAdmin() && isValidProject(incoming()) && isValidId(projectId);
      
      allow update: if (
        // Action: Admin full update
        (isAdmin() && isValidProject(incoming())) ||
        // Action: User increment inquiry count
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['inquiriesCount']) &&
          incoming().inquiriesCount == existing().inquiriesCount + 1
        )
      );
      
      allow delete: if isAdmin();
    }
  }
}
